PORT=3001
ANTHROPIC_API_KEY=your_anthropic_api_key
E2B_API_KEY=your_e2b_api_key
FRONTEND_URL=http://localhost:5173

# Web deploy (Cloudflare Pages — optional, falls back to sandbox preview)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Mobile builds + store publishing (Codemagic)
CODEMAGIC_API_TOKEN=your_codemagic_api_token
CODEMAGIC_APP_ID=your_codemagic_app_id
CODEMAGIC_GIT_PUSH_URL=https://token@github.com/user/repo.git
