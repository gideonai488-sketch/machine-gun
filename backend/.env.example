PORT=3001
ANTHROPIC_API_KEY=your_anthropic_api_key
E2B_API_KEY=your_e2b_api_key
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# Supabase (database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Web deploy (Cloudflare Pages — optional)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Mobile builds (Codemagic — optional)
CODEMAGIC_API_TOKEN=your_codemagic_api_token
CODEMAGIC_APP_ID=your_codemagic_app_id
CODEMAGIC_GIT_PUSH_URL=https://token@github.com/user/repo.git
